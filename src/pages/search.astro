---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCategoryForKpi, getSubcategoryForKpi, kpis } from "../lib/catalog";

const searchIndex = kpis.map((kpi) => {
  const category = getCategoryForKpi(kpi);
  const subcategory = getSubcategoryForKpi(kpi);

  return {
    name: kpi.name,
    description: kpi.description,
    formula: kpi.formula,
    example: kpi.example,
    unit: kpi.unit,
    href: `/${category.slug}/${kpi.slug}`,
    categoryName: category.name,
    categoryHref: `/${category.slug}`,
    subcategoryName: subcategory.name,
    subcategoryHref: `/${category.slug}/s/${subcategory.slug}`,
  };
});
---

<BaseLayout title="Search" description="Search KPI Examples by name, description, and example.">
  <h1 id="search-title">Search KPI Examples</h1>
  <form class="search-page-form" action="/search" method="get">
    <label for="query">Search term</label>
    <div>
      <input
        id="query"
        name="query"
        type="search"
        placeholder="Search KPIs by name or description"
        autofocus
      />
      <button type="submit">Search</button>
    </div>
  </form>
  <div id="search-results" class="card-list" aria-live="polite"></div>
</BaseLayout>

<script define:vars={{ searchIndex }}>
  const form = document.querySelector(".search-page-form");
  const input = document.querySelector("#query");
  const title = document.querySelector("#search-title");
  const results = document.querySelector("#search-results");

  input.value = readQuery();

  function firstSentence(value) {
    if (!value) {
      return "";
    }

    const index = value.indexOf(".");
    return index >= 0 ? value.slice(0, index + 1) : value;
  }

  function normalize(value) {
    return value
      .toLowerCase()
      .normalize("NFKD")
      .replace(/[\u0300-\u036f]/g, "");
  }

  function searchTerms(query) {
    return normalize(query).split(/\s+/).filter(Boolean);
  }

  function matches(item, terms) {
    const haystack = normalize(
      [
        item.name,
        item.description,
        item.formula,
        item.example,
        item.unit,
        item.categoryName,
        item.subcategoryName,
      ]
        .filter(Boolean)
        .join(" "),
    );

    return terms.every((term) => haystack.includes(term));
  }

  function readQuery() {
    const params = new URLSearchParams(window.location.search);
    return params.get("query")?.trim() ?? "";
  }

  function writeQuery(query, method = "replaceState") {
    const url = new URL(window.location.href);

    if (query) {
      url.searchParams.set("query", query);
    } else {
      url.searchParams.delete("query");
    }

    if (method === "pushState") {
      window.history.pushState(null, "", url);
      return;
    }

    window.history.replaceState(null, "", url);
  }

  function render() {
    const query = input.value.trim();

    if (!query) {
      title.textContent = "Search KPI Examples";
      results.textContent = "";
      const empty = document.createElement("p");
      empty.textContent = "Enter a term above to search the static KPI catalog.";
      results.append(empty);
      return;
    }

    const terms = searchTerms(query);
    const matchesForQuery = searchIndex.filter((item) => matches(item, terms));
    title.textContent = `${matchesForQuery.length} ${
      matchesForQuery.length === 1 ? "search result" : "search results"
    } for "${query}"`;

    if (matchesForQuery.length === 0) {
      results.textContent = "";
      const empty = document.createElement("p");
      empty.textContent = "No KPI examples matched this search.";
      results.append(empty);
      return;
    }

    results.replaceChildren(...matchesForQuery.map(renderResult));
  }

  function renderResult(item) {
    const article = document.createElement("article");
    article.className = "card";

    const category = document.createElement("p");
    category.className = "search-category";
    const categoryLink = document.createElement("a");
    categoryLink.href = item.categoryHref;
    categoryLink.textContent = item.categoryName;
    const separator = document.createTextNode(" / ");
    const subcategoryLink = document.createElement("a");
    subcategoryLink.href = item.subcategoryHref;
    subcategoryLink.textContent = item.subcategoryName;
    category.append(categoryLink, separator, subcategoryLink);

    const heading = document.createElement("h2");
    heading.className = "search-result-title";
    const link = document.createElement("a");
    link.href = item.href;
    link.textContent = item.name;
    heading.append(link);

    const description = document.createElement("p");
    description.className = "text-muted";
    description.textContent = firstSentence(item.description);

    article.append(category, heading, description);
    return article;
  }

  input.addEventListener("input", () => {
    writeQuery(input.value.trim());
    render();
  });

  form.addEventListener("submit", (event) => {
    event.preventDefault();
    writeQuery(input.value.trim(), "pushState");
    render();
  });

  window.addEventListener("popstate", () => {
    input.value = readQuery();
    render();
  });

  render();
</script>

<style>
  .search-page-form {
    margin-top: 1rem;
  }

  .search-page-form label {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .search-page-form div {
    display: flex;
    gap: 0.5rem;
  }

  .search-page-form input {
    min-width: 0;
    flex: 1;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    padding: 0.65rem 0.75rem;
    font: inherit;
  }

  .search-page-form button {
    border: 0;
    border-radius: 8px;
    background: #1d4ed8;
    color: white;
    padding: 0.65rem 1rem;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .search-category {
    margin: 0 0 0.4rem;
    font-size: 0.95rem;
  }

  .search-result-title {
    margin: 0;
    font-size: 1.45rem;
  }
</style>
