---
---

<header class="site-header">
  <div class="header-inner">
    <div class="brand-row">
      <a class="brand" href="/" aria-label="Homepage">
        <svg
          aria-hidden="true"
          class="brand-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="12" y1="20" x2="12" y2="10"></line>
          <line x1="18" y1="20" x2="18" y2="4"></line>
          <line x1="6" y1="20" x2="6" y2="16"></line>
        </svg>
        <span>KPI Examples</span>
      </a>
      <form class="search-form" action="/search" method="get">
        <label class="sr-only" for="site-search">Search KPI examples</label>
        <svg
          aria-hidden="true"
          class="search-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M10 10m-7 0a7 7 0 1 0 14 0a7 7 0 1 0 -14 0"></path>
          <path d="M21 21l-6 -6"></path>
        </svg>
        <input id="site-search" name="query" type="search" placeholder="Search KPIs by name or description" />
      </form>
    </div>
    <nav class="nav-links" aria-label="Primary navigation">
      <a href="/contribute">Contribute</a>
      <a href="/about">About</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: white;
    box-shadow: 0 1px 8px rgb(15 23 42 / 0.12);
  }

  .header-inner {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
  }

  .brand-row {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    color: #3185ff;
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    text-decoration: none;
  }

  .brand:hover {
    color: #1d4ed8;
  }

  .brand-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    margin-right: 0.35rem;
  }

  .search-form {
    display: none;
    position: relative;
  }

  .search-form input {
    width: min(52vw, 30rem);
    border: 2px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.7rem 1rem 0.7rem 3.25rem;
    color: #111827;
    font: inherit;
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .search-form input::placeholder {
    color: #6b7280;
    opacity: 1;
  }

  .search-form input:focus {
    border-color: #3185ff;
    outline: 2px solid rgb(49 133 255 / 0.2);
    outline-offset: 0;
  }

  .search-icon {
    position: absolute;
    top: 50%;
    left: 1rem;
    width: 1.5rem;
    height: 1.5rem;
    color: #111827;
    pointer-events: none;
    transform: translateY(-50%);
  }

  .nav-links {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-size: 1rem;
  }

  .nav-links a {
    color: #1f2937;
    text-decoration: none;
  }

  .nav-links a:hover {
    color: #111827;
    text-decoration: underline;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 720px) {
    .search-form {
      display: block;
    }
  }

  @media (max-width: 860px) {
    .brand-row {
      gap: 1rem;
    }

    .search-form input {
      width: min(46vw, 24rem);
    }
  }
</style>
